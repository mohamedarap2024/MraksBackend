# Neon PostgreSQL — use the *pooled* connection string (host contains -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Admin account (created/updated on first API call or npm run db:setup)
ADMIN_USERNAME="Studentportal"
ADMIN_EMAIL="Studentportal@gmail.com"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# Long random secrets — run: npm run secrets:generate
ADMIN_TOKEN=""
STUDENT_TOKEN=""

# Frontend URL(s) on Vercel (comma-separated, no trailing slash)
# Example: https://stdmarks-frontend.vercel.app
CORS_ORIGIN="http://localhost:3000"

# Allow Vercel preview deployments (*.vercel.app) — set true while testing branches
CORS_ALLOW_VERCEL="true"
